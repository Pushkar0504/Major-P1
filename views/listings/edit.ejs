<% layout("/layouts/boilerplate")%>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h1>Edit your Listing</h1>
        <%if(typeof error !== 'undefined'){%>
            <div class="alert alert-danger" role="alert">
                <%= error %>
            </div>
        <%}%>

        <form method="POST" action="/listings/<%=listing._id %>?_method=PUT" class="mt-3 needs-validation enctype="multipart/form-data" novalidate>
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input name="listing[title]" value="<%=listing.title%>" placeholder="enter title" type="text" class="form-control" minlength="3" required>
                <div class="invalid-feedback">Title is required (min 3 characters).</div>
            </div>
            <br/><br/>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea name="listing[description]" class="form-control" minlength="5" required><%=listing.description%></textarea>
                <div class="invalid-feedback">Description is required (min 5 characters).</div>
            </div>
            <br/><br/>

            <div class="mb-3">
                 <img src="<%=listing.image.url%>" alt="Listing Image" class="img-thumbnail mb-3" style="max-width: 300px;">
                 
            </div>

            <div class="mb-3">
                <label for="image" class="form-label"> Upload New Image</label>
                <input name="listing[image][url]"  placeholder="enter image URL" type="file" class="form-control">
                 
            </div>
            <br/><br/>

            <div class="row">
                <div class="mb-3 col-md-6">
                    <label for="price" class="form-label">Price</label>
                    <input name="listing[price]" value="<%=listing.price%>" type="number" class="form-control" min="0" step="0.01" required>
                    <div class="invalid-feedback">Price is required and must be greater than 0.</div>
                </div>
                <div class="mb-3 col-md-6">
                    <label for="country" class="form-label">Country</label>
                    <input name="listing[country]" value="<%=listing.country%>" type="text" class="form-control" minlength="2" required>
                    <div class="invalid-feedback">Country is required (min 2 characters).</div>
                </div>
            </div>

            <br/><br/>

            <div class="mb-3">
                <label for="location" class="form-label">Location</label>
                <input name="listing[location]" value="<%=listing.location%>" type="text" class="form-control" minlength="2" required>
                <div class="invalid-feedback">Location is required (min 2 characters).</div>
            </div>
            <br/><br/>

            <button class="btn btn-dark edit-btn mb-5">Edit</button>
        </form>
    </div>
</div>
