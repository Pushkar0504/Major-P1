<% layout("/layouts/boilerplate")%>

    <div class="row">
        <div class="col-8 offset-2">
            <br/><br/>
            <h1>Create a New Listings</h1>
             

            <form method="POST" action="/listings" class="novalidate" enctype="multipart/form-data">

                <div class="mb-3">
                    <lable for="title" class="form-label">Title</lable>
                    <input name="listing[title]" placeholder="enter title" type="text" class="form-control" minlength="3" required>
                    <div class="valid-feedback">Title looks good.</div>
                </div>

                <br/><br/>

                <div class="mb-3">
                    <lable for="description" class="form-label">Description</lable>
                    <textarea name="listing[description]" placeholder="enter description" class="form-control" minlength="5" required></textarea>
                    <div class="invalid-feedback">Description is required (min 5 characters).</div>
                </div>

                <br><br/>

                <div class="mb-3">
                    <lable for="image" class="form-label">Upload Image</lable>
                    <input name="listing[image]"  type="file" class="form-control" accept="image/*"/>
                    required
                    <div class="invalid-feedback">Please provide a valid URL.</div>
                </div>

                <br/><br/>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <lable for="price" class="form-label">Price</lable>
                        <input name="listing[price]" placeholder="enter price" type="number" class="form-control" min="0" step="0.01" required>
                        <div class="invalid-feedback">Price is required and must be greater than 0.</div>
                    </div>

                    <div class="col-md-8 mb-3">
                        <lable for="country" class="form-label">Country</lable>
                        <input name="listing[country]" placeholder="enter country" type="text" class="form-control" minlength="2" required>
                        <div class="invalid-feedback">Country is required.</div>
                    </div>
                </div>

                <br/><br/>

                <div class="mb-3">
                    <lable for="location" class="form-label">Location</lable>
                    <input name="listing[location]" placeholder="enter location" type="text" class="form-control" minlength="2" required>
                    <div class="invalid-feedback">Location is required (min 2 characters).</div>
                </div>
                

                 

                <br/><br>

                <button class="btn btn-dark add-btn">ADD</button>
                <br/><br/>

            </form>
        </div>
    </div>
<script src="/js/script.js"></script>